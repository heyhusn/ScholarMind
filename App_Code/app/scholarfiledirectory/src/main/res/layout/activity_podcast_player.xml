<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F24"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Header / Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="SCHOLARMIND · PODCAST MODE"
            android:textColor="#5C668D"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/splash_icon_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="2dp"/>
        </FrameLayout>
    </RelativeLayout>

    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="0.8"/>

    <!-- Large Microphone Circle (Increased size to cover space) -->
    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/player_mic_bg"
        android:elevation="6dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎙️"
            android:textSize="76sp"/>
    </FrameLayout>

    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="0.4"/>

    <!-- Paper Title and Subtitle (Increased size to cover space) -->
    <TextView
        android:id="@+id/tvPaperTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Attention Is All You Need"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvPaperAuthor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Audio Explanation · 18 min"
        android:textColor="#7A8FC2"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Audio Progress Bar (Coherent structure) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:id="@+id/progressTrack"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/progress_track">
            <View
                android:id="@+id/progressFill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_fill"/>
        </FrameLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="07:12"
                android:textColor="#7A8FC2"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="18:04"
                android:textColor="#7A8FC2"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Playback speed selectors -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/btnSpeed075"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0.75x"
            android:textColor="#9EA8CC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp"
            android:background="@drawable/player_speed_unselected"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSpeed100"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1.0x"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/player_speed_selected"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSpeed125"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1.25x"
            android:textColor="#9EA8CC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/player_speed_unselected"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSpeed150"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1.5x"
            android:textColor="#9EA8CC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/player_speed_unselected"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSpeed200"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2.0x"
            android:textColor="#9EA8CC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:background="@drawable/player_speed_unselected"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Media Controls (Larger controls to cover space) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="36dp">

        <!-- Previous track -->
        <FrameLayout
            android:id="@+id/btnPrev"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/player_control_small_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⏮"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </FrameLayout>

        <!-- Rewind -->
        <FrameLayout
            android:id="@+id/btnRewind"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/player_control_small_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⏪"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </FrameLayout>

        <!-- Play/Pause -->
        <FrameLayout
            android:id="@+id/btnPlayPause"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/player_control_play_bg"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvPlayIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:layout_marginStart="4dp"/>
        </FrameLayout>

        <!-- Fast Forward -->
        <FrameLayout
            android:id="@+id/btnFF"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/player_control_small_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⏩"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </FrameLayout>

        <!-- Next track -->
        <FrameLayout
            android:id="@+id/btnNext"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/player_control_small_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⏭"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Live Transcript Card (Made slightly larger to fill space) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/player_transcript_bg"
        android:padding="22dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE TRANSCRIPT"
            android:textColor="#5E6890"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTranscriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&quot;The paper's central claim is that attention alone is sufficient to model sequence-to-sequence tasks, completely replacing recurrent networks…&quot;"
            android:textColor="#E2E8FF"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1.2"/>

</LinearLayout>
