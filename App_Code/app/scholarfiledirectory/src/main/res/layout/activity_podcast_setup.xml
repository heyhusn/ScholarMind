<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B4B"
    android:padding="20dp">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/splash_icon_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="2dp"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Podcast Setup"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configure your AI Podcast"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select how technical you want the generated audio explanation to be."
                android:textColor="#9EA8CC"
                android:textSize="14sp"
                android:layout_marginBottom="28dp"/>

            <!-- Technicality Level Section Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Technicality Level"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Two selectable cards side-by-side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <!-- Basic Card -->
                <LinearLayout
                    android:id="@+id/cardBasic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/podcast_card_selected"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="32sp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvBasicTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBasicDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Simple &amp; high-level summaries"
                        android:textColor="#E2E8FF"
                        android:textSize="11sp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Deep Card -->
                <LinearLayout
                    android:id="@+id/cardDeep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/podcast_card_unselected"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧠"
                        android:textSize="32sp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvDeepTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deep Tech"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDeepDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Detailed equations &amp; methods"
                        android:textColor="#9EA8CC"
                        android:textSize="11sp"
                        android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Additional Instructions Section Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Additional Instructions"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- EditText taking three lines -->
            <EditText
                android:id="@+id/etInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top|start"
                android:hint="If you want to add additional instruction (optional)"
                android:textColorHint="#5E6890"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:padding="16dp"
                android:background="@drawable/podcast_edittext_bg"
                android:layout_marginBottom="24dp"
                android:inputType="textMultiLine"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Generate Button -->
            <android.widget.Button
                android:id="@+id/btnGenerate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Generate Podcast"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/podcast_btn_bg"
                android:elevation="4dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
