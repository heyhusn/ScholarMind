<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FF">

    <!--  ── TOP BAR ──  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/splash_icon_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Upload Paper"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#0D1B4B"/>

        <!-- PDF count badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/limit_info_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">
            <TextView
                android:id="@+id/tvPdfCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/5 PDFs"
                android:textColor="#3A5CFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!--  ── MAIN SCROLL CONTENT ──  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="16dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <!-- ── Limit Info Banner ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/limit_info_bg"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Upload limit: 5 PDFs max · 50 MB per file · One upload at a time"
                    android:textColor="#4338CA"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!--  ── DROP ZONE ──  -->
            <LinearLayout
                android:id="@+id/llDropZone"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:background="@drawable/dashed_border"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp">
                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/upload_icon_ring_bg"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="📤"
                        android:textSize="28sp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Drop your PDF here"
                    android:textSize="16sp"
                    android:textColor="#0D1B4B"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Supports .pdf up to 50 MB"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="— or —"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>

                <!--  Browse button  -->
                <TextView
                    android:id="@+id/btnBrowse"
                    android:layout_width="130dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="10dp"
                    android:text="Browse Files"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/splash_btn_bg"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- ── Uploaded Files Section (hidden until first upload) ── -->
            <LinearLayout
                android:id="@+id/sectionUploadedFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Uploaded Files"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#0D1B4B"/>
                    <TextView
                        android:id="@+id/tvUploadedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 of 5"
                        android:textSize="12sp"
                        android:textColor="#3A5CFF"/>
                </LinearLayout>

                <!-- Uploaded file cards will be added here dynamically -->
                <LinearLayout
                    android:id="@+id/llUploadedFilesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!--  ── BOTTOM CTA ──  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btnUploadAnalyze"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="🚀  Smart Analyze"
            android:textSize="16sp"
            android:letterSpacing="0.01"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/splash_btn_bg"
            android:textStyle="bold"
            android:alpha="0.5"/>
    </LinearLayout>

</LinearLayout>