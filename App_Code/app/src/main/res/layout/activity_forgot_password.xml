<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E3FE8"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/circle_border_bg" android:gravity="center"
            android:text="🔑"
            android:textSize="30sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="ScholarMind"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset your password"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="#0F1117"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enter your university email and we'll send you a secure reset link."
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:background="#EFF6FF"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="ℹ️"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check your university inbox after submitting. The reset link expires in 15 minutes."
                android:textColor="#1E40AF"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL ADDRESS"
            android:textColor="#374151"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etResetEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:background="#F3F4F6"
            android:hint="you@university.edu"
            android:inputType="textEmailAddress"
            android:textColor="#0F1117"
            android:textColorHint="#9CA3AF"
            android:paddingHorizontal="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendReset"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#3A5CFF"
            android:text="Send Reset Link"
            android:textColor="#FFFFFF"
            app:cornerRadius="14dp" />

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="Remember your password? Sign In"
            android:textColor="#6B7280"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>