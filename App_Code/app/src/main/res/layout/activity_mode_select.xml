<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">



    <!--  ── TOP BAR ──  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="#F3F4F6">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textSize="16sp"
                android:textColor="#374151"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPaperTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Explain Paper"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F1117"
                android:transitionName="paper_title_transition"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/tvPaperAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose how you want to understand this paper"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

    <!--  ── SCROLLABLE CARDS ──  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="6dp"
            android:paddingBottom="14dp">

            <!--  ── BEGINNER MODE CARD ──  -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="168dp"
                android:layout_marginBottom="11dp">

                <LinearLayout
                    android:id="@+id/cardBeginner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#ECFDF5">
                    <TextView android:layout_width="match_parent" android:layout_height="30dp" android:text="🎓" android:textSize="30sp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Beginner Mode" android:textSize="16sp" android:textStyle="bold" android:textColor="#065F46"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="7dp" android:text="Plain language, everyday analogies, no technical jargon. Perfect for first-time readers." android:textSize="12sp" android:lineSpacingMultiplier="1.5" android:textColor="#6B7280"/>
                    <TextView android:id="@+id/btnSelectBeginner" android:layout_width="120dp" android:layout_height="26dp" android:text="Select Beginner →" android:textSize="11sp" android:textColor="#065F46" android:gravity="center" android:background="#D1FAE5"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="9dp"
                    android:text="⭐ Recommended"
                    android:textSize="9sp"
                    android:textColor="#065F46"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:gravity="center_vertical"
                    android:background="#A7F3D0"/>
            </FrameLayout>

            <!--  ── TECHNICAL MODE CARD ──  -->
            <LinearLayout
                android:id="@+id/cardTechnical"
                android:layout_width="match_parent"
                android:layout_height="168dp"
                android:layout_marginBottom="11dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#EFF6FF">
                <TextView android:layout_width="match_parent" android:layout_height="30dp" android:text="🔬" android:textSize="30sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Technical Mode" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E3FE8"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="7dp" android:text="Full academic depth with equations, methodology analysis, and expert-level explanations." android:textSize="12sp" android:lineSpacingMultiplier="1.5" android:textColor="#6B7280"/>
                <TextView android:id="@+id/btnSelectTechnical" android:layout_width="122dp" android:layout_height="26dp" android:text="Select Technical →" android:textSize="11sp" android:textColor="#1E3FE8" android:gravity="center" android:background="#DBEAFE"/>
            </LinearLayout>

            <!--  ── PODCAST MODE CARD ──  -->
            <LinearLayout
                android:id="@+id/cardPodcast"
                android:layout_width="match_parent"
                android:layout_height="168dp"
                android:layout_marginBottom="11dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFF7ED">
                <TextView android:layout_width="match_parent" android:layout_height="30dp" android:text="🎙️" android:textSize="30sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Podcast Mode" android:textSize="16sp" android:textStyle="bold" android:textColor="#C2410C"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="7dp" android:text="AI-narrated audio explanation. Listen while commuting or relaxing, hands-free." android:textSize="12sp" android:lineSpacingMultiplier="1.5" android:textColor="#6B7280"/>
                <TextView android:id="@+id/btnSelectPodcast" android:layout_width="122dp" android:layout_height="26dp" android:text="Select Podcast →" android:textSize="11sp" android:textColor="#C2410C" android:gravity="center" android:background="#FFEDD5"/>
            </LinearLayout>



        </LinearLayout>
    </ScrollView>
</LinearLayout>