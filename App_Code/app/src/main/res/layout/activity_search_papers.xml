<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar / Header Area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="36dp"
            android:paddingBottom="12dp">

            <!-- Back Button (Light theme circle) -->
            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_card_beginner"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="‹"
                    android:textColor="#3A5CFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Screen Title (Dark Navy text) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Discover Papers"
                android:textColor="#0D1B4B"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Search Input Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔎"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etSearchQuery"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search title, author, keyword..."
                    android:textColor="#0D1B4B"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#9CA3AF"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    android:contentDescription="Clear" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Horizontal Category Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:layout_marginVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/chipML"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_beginner"
                    android:textColor="#3A5CFF"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Machine Learning"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipPhysics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_technical"
                    android:textColor="#8A2BE2"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Quantum Physics"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipBio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_podcast"
                    android:textColor="#10B981"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Bioinformatics"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipNeuro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_beginner"
                    android:textColor="#3A5CFF"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Neuroscience"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipMed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_technical"
                    android:textColor="#8A2BE2"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Cancer Research"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Dynamic Results List Header (Dark grey text) -->
        <TextView
            android:id="@+id/tvResultsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trending Papers"
            android:textColor="#6B7280"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Frame Layout holding RecyclerView, Shimmer, and Empty State -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- RecyclerView list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPapers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />

            <!-- Progress Loader (Blue spinner) -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="#3A5CFF"
                android:visibility="gone" />

            <!-- Empty / Failure State -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No results found"
                    android:textColor="#0D1B4B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvEmptyDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Try checking your spelling or search terms."
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
