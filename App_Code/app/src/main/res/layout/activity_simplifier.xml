<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/rootContainer" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F8F9FA">
    <!--  ═══════════════════════════════════════════════
             TOP NAVIGATION BAR  (height 52 dp)
             Back button + Screen title "Simplify Text"
        ═══════════════════════════════════════════════  -->
    <LinearLayout android:id="@+id/topNavBar" android:layout_width="0dp" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="10dp" android:paddingBottom="8dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <!--  Back button background pill  -->
        <FrameLayout android:id="@+id/btnBack" android:layout_width="34dp" android:layout_height="34dp" android:background="#EFEFEF" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="←" android:textColor="#0F1117" android:textSize="16sp" />
        </FrameLayout>
        <!--  Title  -->
        <TextView android:id="@+id/tvScreenTitle" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1" android:layout_marginStart="10dp" android:text="Simplify Text" android:textColor="#1A1A2A" android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical" />
    </LinearLayout>
    <!--  ═══════════════════════════════════════════════
             SUBTITLE ROW  (height 21 dp)
             "Tap any highlighted term for AI explanation"
        ═══════════════════════════════════════════════  -->
    <LinearLayout android:id="@+id/subtitleRow" android:layout_width="0dp" android:layout_height="21dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingBottom="7dp" app:layout_constraintTop_toBottomOf="@id/topNavBar" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView android:id="@+id/tvSubtitle" android:layout_width="0dp" android:layout_height="14dp" android:layout_weight="1" android:text="Tap any highlighted term for AI explanation" android:textColor="#8A8A99" android:textSize="11sp" android:gravity="center_vertical" />
    </LinearLayout>
    <!--  ═══════════════════════════════════════════════
             LEVEL SELECTOR TABS  (height 43 dp)
             School (active/blue) | Undergrad | Researcher
        ═══════════════════════════════════════════════  -->
    <LinearLayout android:id="@+id/tabsRow" android:layout_width="0dp" android:layout_height="43dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="9dp" app:layout_constraintTop_toBottomOf="@id/subtitleRow" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <!--  School Tab (selected)  -->
        <TextView android:id="@+id/tabSchool" android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1" android:layout_marginEnd="5dp" android:text="School" android:textColor="#FFFFFF" android:textSize="11sp"  android:gravity="center" android:background="#2563EB" android:clickable="true" android:focusable="true"/>
        <!--  Undergrad Tab  -->
        <TextView android:id="@+id/tabUndergrad" android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1" android:layout_marginEnd="5dp" android:text="Undergrad" android:textColor="#8A8A99" android:textSize="11sp"  android:gravity="center" android:background="#F3F4F6" android:clickable="true" android:focusable="true"/>
        <!--  Researcher Tab  -->
        <TextView android:id="@+id/tabResearcher" android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1" android:text="Researcher" android:textColor="#8A8A99" android:textSize="11sp"  android:gravity="center" android:background="#F3F4F6" android:clickable="true" android:focusable="true"/>
    </LinearLayout>
    <!--  ═══════════════════════════════════════════════
             SCROLLABLE CONTENT AREA
             Contains: text card(s) + AI explanation panel
        ═══════════════════════════════════════════════  -->
    <ScrollView android:id="@+id/scrollContent" android:layout_width="0dp" android:layout_height="0dp" android:fillViewport="true" android:paddingTop="10dp" android:paddingBottom="14dp" android:clipToPadding="false" app:layout_constraintTop_toBottomOf="@id/tabsRow" app:layout_constraintBottom_toTopOf="@id/bottomNavBar" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
            <!--  ─────────────────────────────────────────
                             TEXT CONTENT CARD
                             White rounded card, border #E5E7EB
                        ─────────────────────────────────────────  -->
            <FrameLayout android:id="@+id/cardTextContent" android:layout_width="339dp" android:layout_height="wrap_content" android:layout_marginBottom="7dp" android:background="#FFFFFF">
                <!--  Rich-text paragraph
                                     (In production, use a SpannableString to colour
                                      highlighted terms: yellow=#FDE68A / blue=#DBEAFE)  -->
                <TextView android:id="@+id/tvArticleText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="15dp" android:textSize="12.5sp" android:lineSpacingMultiplier="1.75" android:textColor="#0F1117"  android:text="The model employs stochastic gradient descent with a custom learning rate schedule using warmup steps to stabilise early training dynamics across high-dimensional parameter spaces via the Adam optimizer with β₁=0.9 and β₂=0.98…"/>
            </FrameLayout>
            <!--  ─────────────────────────────────────────
                             DIVIDER + SECTION LABEL
                        ─────────────────────────────────────────  -->
            <LinearLayout android:id="@+id/sectionLabelRow" android:layout_width="339dp" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="5dp" android:paddingBottom="0dp" android:layout_marginBottom="7dp">
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>
                <TextView android:id="@+id/tvSectionLabel" android:layout_width="match_parent" android:layout_height="13dp" android:layout_marginTop="9dp" android:text="📌 Selected term explanation" android:textColor="#8A8A99" android:textSize="10sp"  android:gravity="center_vertical"/>
            </LinearLayout>
            <!--  ─────────────────────────────────────────
                             AI EXPLANATION CARD  (dark background)
                             Title + Body + Analogy overlay
                        ─────────────────────────────────────────  -->
            <LinearLayout android:id="@+id/cardAiExplanation" android:layout_width="339dp" android:layout_height="211dp" android:orientation="vertical" android:padding="16dp" android:layout_marginBottom="7dp" android:background="#1A1A2E">
                <!--  "SIMPLIFYING…" label  -->
                <TextView android:id="@+id/tvSimplifyingLabel" android:layout_width="match_parent" android:layout_height="11dp" android:text="SIMPLIFYING…" android:textColor="#4DFFFFFF" android:textSize="9sp" android:letterSpacing="0.1" android:textAllCaps="true"  android:gravity="center_vertical"/>
                <!--  Term heading  -->
                <TextView android:id="@+id/tvTermHeading" android:layout_width="match_parent" android:layout_height="20dp" android:layout_marginTop="5dp" android:text="Stochastic Gradient Descent" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:letterSpacing="-0.02"  android:gravity="center_vertical"/>
                <!--  Definition body  -->
                <TextView android:id="@+id/tvTermDefinition" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="5dp" android:text="A method to train AI by making small corrections after each guess. Instead of processing all data at once, it learns from small random batches — making it faster and more practical for large datasets." android:textColor="#A6FFFFFF" android:textSize="12sp" android:lineSpacingMultiplier="1.6"  android:gravity="top"/>
                <!--  Analogy pill overlay  -->
                <LinearLayout android:id="@+id/analogyOverlay" android:layout_width="match_parent" android:layout_height="55dp" android:orientation="vertical" android:paddingStart="9dp" android:paddingEnd="9dp" android:paddingTop="13dp" android:paddingBottom="9dp" android:background="#252540" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvAnalogy" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💡 Think of it as adjusting your aim after each dart throw, rather than waiting 1,000 throws to correct." android:textColor="#73FFFFFF" android:textSize="11sp" android:textStyle="italic" android:lineSpacingMultiplier="1.45" />
                </LinearLayout>
            </LinearLayout>
            <!--  ─────────────────────────────────────────
                             "← Back to Summary" button card
                        ─────────────────────────────────────────  -->
            <LinearLayout android:id="@+id/btnBackToSummary" android:layout_width="339dp" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center" android:paddingTop="4dp" android:background="#1A1A2E" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="← Back to Summary" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.01"  android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!--  ═══════════════════════════════════════════════
             BOTTOM NAVIGATION BAR
             Home | History | [FAB: Share] | Cards | Profile(active)
        ═══════════════════════════════════════════════  -->
    <LinearLayout android:id="@+id/bottomNavBar" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="#FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <!--  Home tab (inactive, 35% opacity)  -->
        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:alpha="0.35" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="19dp" android:layout_height="19dp" android:text="🏠" android:textSize="19sp" android:gravity="center"/>
            <TextView android:layout_width="27dp" android:layout_height="11dp" android:text="Home" android:textColor="#0F1117" android:textSize="9sp"  android:gravity="center"/>
        </LinearLayout>
        <!--  History tab (inactive, 35% opacity)  -->
        <LinearLayout android:id="@+id/navHistory" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:alpha="0.35" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="19dp" android:layout_height="19dp" android:text="📚" android:textSize="19sp" android:gravity="center"/>
            <TextView android:layout_width="32dp" android:layout_height="11dp" android:text="History" android:textColor="#0F1117" android:textSize="9sp"  android:gravity="center"/>
        </LinearLayout>
        <!--  Center FAB placeholder (Share) — actual FAB positioned above bar  -->
        <FrameLayout android:id="@+id/navSharePlaceholder" android:layout_width="48dp" android:layout_height="34dp">
            <!--  The real FAB sits above the bar via negative top margin  -->
        </FrameLayout>
        <!--  Cards tab (inactive, 35% opacity)  -->
        <LinearLayout android:id="@+id/navCards" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:alpha="0.35" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="19dp" android:layout_height="19dp" android:text="🃏" android:textSize="19sp" android:gravity="center"/>
            <TextView android:layout_width="27dp" android:layout_height="11dp" android:text="Cards" android:textColor="#0F1117" android:textSize="9sp"  android:gravity="center"/>
        </LinearLayout>
        <!--  Profile tab (ACTIVE)  -->
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="19dp" android:layout_height="19dp" android:text="👤" android:textSize="19sp" android:gravity="center"/>
            <TextView android:layout_width="29dp" android:layout_height="11dp" android:text="Profile" android:textColor="#2563EB" android:textSize="9sp"  android:gravity="center"/>
            <!--  Active dot indicator  -->
            <View android:layout_width="4dp" android:layout_height="4dp" android:layout_marginTop="2dp" android:layout_gravity="center_horizontal" android:background="#2563EB"/>
        </LinearLayout>
    </LinearLayout>
    <!--  ═══════════════════════════════════════════════
             CENTER FAB — Share / Upload button
             Positioned absolutely above the bottom nav
        ═══════════════════════════════════════════════  -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/fabShare" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_share" android:contentDescription="Share" app:backgroundTint="@null" app:elevation="8dp" app:layout_constraintBottom_toTopOf="@id/bottomNavBar" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="-14dp" />
</androidx.constraintlayout.widget.ConstraintLayout>