<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="28dp"
    android:background="@drawable/dialog_upload_bg">

    <!-- Top upload animation icon -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp">
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/upload_icon_ring_bg"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="📤"
            android:textSize="34sp"/>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Uploading PDF"
        android:textColor="#0D1B4B"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- Filename -->
    <TextView
        android:id="@+id/tvDialogFilename"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="document.pdf"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:gravity="center"
        android:ellipsize="middle"
        android:singleLine="true"/>

    <!-- Progress bar track -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/upload_progress_track_bg">
        <View
            android:id="@+id/uploadProgressFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/upload_progress_fill_bg"/>
    </FrameLayout>

    <!-- Percent text -->
    <TextView
        android:id="@+id/tvDialogPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="0%"
        android:textColor="#3A5CFF"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <!-- Status subtext -->
    <TextView
        android:id="@+id/tvDialogStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Please wait, uploading your document…"
        android:textColor="#9CA3AF"
        android:textSize="11sp"
        android:gravity="center"/>

    <!-- Limit info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/limit_info_bg"
        android:padding="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ℹ️"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Max 5 PDFs · Max 50 MB per file"
            android:textColor="#6B7280"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
