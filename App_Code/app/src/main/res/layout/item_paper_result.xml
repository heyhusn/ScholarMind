<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Badges (Open Access and Citations) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Primary Topic Pill -->
            <TextView
                android:id="@+id/tvTopic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_beginner"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="#3A5CFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Machine Learning"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Open Access Badge -->
            <TextView
                android:id="@+id/tvOABadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_podcast"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="#10B981"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="🔓 OPEN ACCESS"
                android:layout_marginEnd="6dp"
                android:visibility="visible" />

            <!-- Citation Badge -->
            <TextView
                android:id="@+id/tvCitationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_technical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="#8A2BE2"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="★ 128" />

        </LinearLayout>

        <!-- Paper Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attention Is All You Need"
            android:textColor="#0D1B4B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="6dp" />

        <!-- Authors -->
        <TextView
            android:id="@+id/tvAuthors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ashish Vaswani, Noam Shazeer, Niki Parmar, Jakob Uszkoreit"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="8dp" />

        <!-- Footer Row: Venue and Year -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Venue -->
            <TextView
                android:id="@+id/tvVenue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Advances in Neural Information Processing Systems"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Year -->
            <TextView
                android:id="@+id/tvYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2017"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
