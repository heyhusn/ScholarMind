<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E8EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvRefNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[1]"
            android:textColor="#2563EB"
            android:textStyle="bold"
            android:textSize="13sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvRefTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Neural Machine Translation by Jointly Learning to Align and Translate"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRefAuthors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bahdanau et al. · ICLR 2015"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvRefDoi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="doi.org/10.48550"
                android:textColor="#2563EB"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>